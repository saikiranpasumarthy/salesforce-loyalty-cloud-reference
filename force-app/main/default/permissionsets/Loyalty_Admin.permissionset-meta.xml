<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Full loyalty administration: all agent capabilities plus batch job scheduling, tier management, privacy deletion, and Custom Metadata editing.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Loyalty Admin</label>

    <!-- Apex Class Access — all loyalty classes -->
    <classAccesses>
        <apexClass>LoyaltyEnrollmentController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>LoyaltyLoginController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>LoyaltyCompositeAPIController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>LoyaltyLookupController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PrivacyDeletionAPIController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>RCCCardBatchProcessor</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PointsExpiryBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PointsExpiryScheduler</apexClass>
        <enabled>true</enabled>
    </classAccesses>

