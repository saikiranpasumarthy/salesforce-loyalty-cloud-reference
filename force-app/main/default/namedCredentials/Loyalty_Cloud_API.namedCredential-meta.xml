<?xml version="1.0" encoding="UTF-8"?>
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Loyalty Cloud API</label>
    <name>Loyalty_Cloud_API</name>
    <protocol>NoAuthentication</protocol>
    <endpoint>https://concord87-dev-ed.develop.my.salesforce.com/services/data/v66.0</endpoint>
    <!--
    MANUAL SETUP REQUIRED AFTER DEPLOY:
    Named Credentials with OAuth 2.0 must be completed in Setup UI.
    1. Setup > Security > Named Credentials > Loyalty Cloud API > Edit
    2. Change Auth Protocol to: OAuth 2.0
    3. Set Auth Provider to your Connected App Auth Provider
    4. Click Save — authenticate when prompted
    For test classes: LoyaltyMockHttpCallout intercepts all callouts.
    Protocol is set to NoAuthentication so the deploy succeeds without
    a pre-configured Auth Provider. Change to OAuth after deploy.
    -->
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
</NamedCredential>
