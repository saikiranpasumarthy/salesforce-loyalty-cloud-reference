<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Published when an order is cancelled. Consumed by OrderCancellationEventHandler to reverse vouchers and debit accrued points.</description>
    <eventType>HighVolume</eventType>
    <label>Order Cancellation Event</label>
    <pluralLabel>Order Cancellation Events</pluralLabel>
    <publishBehavior>PublishAfterCommit</publishBehavior>
    <fields>
        <fullName>Order_Id__c</fullName>
        <description>External order identifier matching the original Order_Fulfilment_Event__e.</description>
        <label>Order ID</label>
        <length>50</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>Contact_Id__c</fullName>
        <label>Contact ID</label>
        <length>18</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>Loyalty_Member_Id__c</fullName>
        <label>Loyalty Member ID</label>
        <length>50</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>Points_To_Reverse__c</fullName>
        <description>Number of points accrued on the original order to be debited.</description>
        <label>Points To Reverse</label>
        <precision>12</precision>
        <scale>2</scale>
        <type>Number</type>
    </fields>
    <fields>
        <fullName>Voucher_Ids_JSON__c</fullName>
        <description>JSON array of voucher IDs redeemed on the order that must be cancelled.</description>
        <label>Voucher IDs JSON</label>
        <length>4096</length>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>Cancelled_At__c</fullName>
        <label>Cancelled At</label>
        <type>DateTime</type>
    </fields>
</CustomObject>
