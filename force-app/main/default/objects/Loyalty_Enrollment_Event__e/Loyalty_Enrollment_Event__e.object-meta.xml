<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Published by LoyaltyEnrollmentService after a successful Loyalty Cloud enrollment. Consumed by downstream flows and integrations (e.g., Welcome Email Flow, Epsilon sync).</description>
    <eventType>HighVolume</eventType>
    <label>Loyalty Enrollment Event</label>
    <pluralLabel>Loyalty Enrollment Events</pluralLabel>
    <publishBehavior>PublishAfterCommit</publishBehavior>
    <fields>
        <fullName>Contact_Id__c</fullName>
        <description>SFDC Contact Id of the newly enrolled member.</description>
        <label>Contact ID</label>
        <length>18</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>Loyalty_Member_Id__c</fullName>
        <description>Loyalty Cloud member identifier assigned at enrollment.</description>
        <label>Loyalty Member ID</label>
        <length>50</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>Member_Type__c</fullName>
        <description>Retail, Pro, or Student.</description>
        <label>Member Type</label>
        <length>20</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>Program_Name__c</fullName>
        <description>Loyalty program name from Loyalty_Program_Config__mdt.</description>
        <label>Program Name</label>
        <length>100</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>Enrolled_At__c</fullName>
        <description>Timestamp of the enrollment event.</description>
        <label>Enrolled At</label>
        <type>DateTime</type>
    </fields>
</CustomObject>
